
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/form.css') }}">
{% endblock %}

{% block body %}

<div class="custom-container">
    <div class="custom-card">
        <div class="custom-card-body">

            <h4>{{ button_title|default("Ajouter un mouvement de bons validé") }}</h4>

            {{ form_start(form, {'attr': {'class': 'custom-form'}}) }}

            {# ✅ ERREURS GLOBALES #}
            {% if form.vars.errors|length > 0 %}
                <div class="form-global-errors">
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            <div class="form-grid">

                {% for field in form %}
                    {% if field.vars.name != '_token' %}
                        {% if field.vars.block_prefixes[1] == 'hidden' %}
                            {# Champs cachés : juste le widget #}
                            {{ form_widget(field) }}
                        {% else %}
                            {# Champs visibles : avec label et structure complète #}
                            <div class="form-group">
                                {{ form_label(field, null, {'label_attr': {'class': 'custom-label'}}) }}
                                {{ form_widget(field, {'attr': {'class': 'custom-input'}}) }}
                                {{ form_errors(field) }}
                            </div>
                        {% endif %}
                    {% endif %}
                {% endfor %}

            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    {{ button_label|default('Ajouter') }}
                </button>

                <a href="{{ path('app_mvt_bons_valide_index') }}" class="btn-secondary">
                    Annuler
                </a>
            </div>

            {{ form_end(form) }}

        </div>
    </div>
</div>

{% endblock %}
