{% extends 'base.html.twig' %}

{% block title %}MvtBonsValide index{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/mvt_bon_valide_list.css') }}">    
{% endblock %}

{% block body %}
    <div class="entete">

        <!-- HEADER / FILTRE -->
        <form method="get" action="{{ path('app_mvt_bons_valide_index') }}" 
              class="row my-4 px-3 align-items-end">

            <!-- Date -->
            <div class="col-md-3">
                <label class="form-label">Date des bons :</label>
                <input type="date" name="date_filter" class="form-control"
                       value="{{ app.request.get('date_filter') }}">
            </div>

            <!-- Bouton afficher -->
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Afficher
                </button>
            </div>

            <!-- Boutons droite -->
            <div class="col-md-7 d-flex justify-content-end gap-2">

                <a class="btn btn-outline-secondary" id="refreshTable" title="Rafraîchir">
                    <i class="bi bi-arrow-clockwise"></i>
                </a>

                <a class="btn btn-primary btn-add" href="{{ path('app_mvt_bons_valide_new') }}">
                    <i class="bi bi-plus-circle"></i> Ajouter
                </a>

            </div>

        </form>
        <!-- CONTAINER -->
        <div class="custom-container">
        
            {% for mvt in mvt_bons_valides %}
        
            <div class="custom-card mb-4">
                <div class="custom-card-body">
                
                    <h4 class="text-center mb-4">
                        Mouvement du {{ mvt.D_BONS }}
                    </h4>
                
                    <div class="form-container">
                    
                        {# ================= DATE ================= #}
                        <div class="form-row-top">
                            <div class="form-group">
                                <label class="custom-label">Date des Bons</label>
                                <div class="custom-input">
                                    <span class="custom-input-small"><strong>{{ mvt.D_BONS }}</strong></span>
                                </div>
                            </div>
                        </div>
                    
                        {# ================= TAUX ================= #}
                        <div class="form-section">
                            <h3 class="section-title">Taux Moyen Pondéré</h3>
                        
                            <div class="taux-grid">
                            
                                <div class="taux-column">
                                    <div class="form-group-inline">
                                        <span class="custom-label-inline">4 semaines :</span>
                                        <span class="custom-input-small"><strong>{{ mvt.taux[1] ?? '-' }}</strong></span>
                                    </div>
                                
                                    <div class="form-group-inline">
                                        <span class="custom-label-inline">24 semaines :</span>
                                        <span class="custom-input-small"><strong>{{ mvt.taux[3] ?? '-' }}</strong></span>
                                    </div>
                                
                                    <div class="form-group-inline">
                                        <span class="custom-label-inline">52 semaines :</span>
                                        <span class="custom-input-small"><strong>{{ mvt.taux[5] ?? '-' }}</strong></span>
                                    </div>
                                </div>
                            
                                <div class="taux-column">
                                    <div class="form-group-inline">
                                        <span class="custom-label-inline">12 semaines :</span>
                                        <span class="custom-input-small"><strong>{{ mvt.taux[2] ?? '-' }}</strong></span>
                                    </div>
                                
                                    <div class="form-group-inline">
                                        <span class="custom-label-inline">26 semaines :</span>
                                        <span class="custom-input-small"><strong>{{ mvt.taux[4] ?? '-' }}</strong></span>
                                    </div>
                                </div>
                            
                            </div>
                        </div>
                    
                        {# ================= OFFRES ================= #}
                        <div class="form-section">
                            <h3 class="section-title">Offres Compétitives</h3>
                        
                            <div class="offres-grid">
                            
                                <div class="form-group-inline">
                                    <span class="custom-label-inline">Montant annoncé :</span>
                                    <span class="custom-input-small"><strong>{{ mvt.MAN ?? '-' }}</strong></span>

                                </div>
                            
                                <div class="form-group-inline">
                                    <span class="custom-label-inline">Montant soumis :</span>
                                    <span class="custom-input-small"><strong>{{ mvt.MSM1 ?? '-' }}</strong></span>
                                </div>
                            
                                <div class="form-group-inline">
                                    <span class="custom-label-inline">Montant adjugé :</span>
                                    <span class="custom-input-small"><strong>{{ mvt.MAD1 ?? '-' }}</strong></span>
                                </div>
                            
                            </div>
                        </div>
                    
                    </div>
                
                    {# ================= ACTIONS ================= #}
                    <div class="form-actions">
                    
                        <a href="{{ path('app_mvt_bons_valide_show', {'id': mvt.id}) }}"
                           class="btn-action btn-view">
                            <i class="bi bi-eye-fill"></i> Voir détails
                        </a>
                    
                        <a href="{{ path('app_mvt_bons_valide_edit', {'id': mvt.id}) }}"
                           class="btn-action btn-edit">
                            <i class="bi bi-pencil"></i> Modifier
                        </a>
                    
                        <form method="post"
                              action="{{ path('app_mvt_bons_valide_delete', {'id': mvt.id}) }}"
                              onsubmit="return confirm('Confirmer la suppression ?');"
                              style="display:inline;">
                    
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ mvt.D_BONS) }}">
                    
                            <button type="submit" class="btn-action btn-delete">
                                <i class="bi bi-trash"></i> Supprimer
                            </button>
                        
                        </form>
                    
                    </div>
                
                </div>
            </div>
        
            {% else %}
                <div class="alert alert-info text-center">
                    Aucune donnée disponible
                </div>
            {% endfor %}
            
        </div>
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    </div>


<div id="pagination-wrapper"></div>

<script src="{{ asset('js/secteur_valide.js') }}"></script>

{% block javascripts %}
<script>
document.addEventListener("DOMContentLoaded", function () {
    const refreshBtn = document.getElementById("refreshTable");

    refreshBtn.addEventListener("click", function () {
        location.reload();
    });
});
</script>
{% endblock %}

{% endblock %}